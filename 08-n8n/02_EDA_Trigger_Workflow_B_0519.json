    {
      "parameters": {
        "jsCode": "// 从上一步 \"Get Root Post\" 节点的输出中，获取消息内容\nconst rootMessage = $json.message; // 这是原始告警消息全文\n\n// 1. 使用最终修正的正则表达式\nconst match = rootMessage.match(/\\*\\*Incident ID:\\*\\*\\s+\\\\`(.*?)`/);\n\nif (!match || !match[1]) {\n  throw new Error(\"在原始消息中找不到 Incident ID\");\n}\nconst incidentSessionId = match[1];\n\n// 2. 从 \"Mattermost Trigger\" 节点获取用户本次回复的具体内容\nconst userMessage = $('Mattermost Trigger').item.json.body.text.replace('!ai', '').trim();\n\n// 3. 从 \"Get Reply Details\" 节点获取回复所需的频道和帖子ID\nconst channelId = $('Get Reply Details').item.json.channel_id;\nconst rootId = $('Get Reply Details').item.json.root_id;\n\n// 4. 将所有关键信息打包输出\nreturn [{\n  json: {\n    incidentSessionId: incidentSessionId,\n    currentUserMessage: userMessage, \n    channelId: channelId,\n    rootId: rootId,\n    originalContext: rootMessage // 将原始告警消息也输出 \n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
